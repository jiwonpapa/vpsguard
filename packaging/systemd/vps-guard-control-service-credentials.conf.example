# Install as /etc/systemd/system/vps-guard-control.service.d/20-service-credentials.conf.
# Source files must be regular root-owned files with mode 0600.
[Service]
LoadCredential=mysql-monitor-url:/etc/vps-guard/secrets/mysql-monitor-url
LoadCredential=redis-monitor-url:/etc/vps-guard/secrets/redis-monitor-url
